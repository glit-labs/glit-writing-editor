---
layout: none
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<!--
  Release-notes Atom feed. Overrides jekyll-feed's default (empty, since the
  site has no _posts) with one <entry> per English release note that carries a
  `date` in its front matter. Add a `date` to a new releases/<platform>/<ver>/en.md
  and it appears here automatically; undated (TBD) releases are skipped.
  The <title> is built from the URL (platform + version) so entries stay
  distinct across platforms.
-->
{%- assign entries = "" | split: "" -%}
{%- for page in site.html_pages -%}
  {%- if page.url contains "/releases/" and page.url contains "/en.html" and page.date -%}
    {%- assign entries = entries | push: page -%}
  {%- endif -%}
{%- endfor -%}
{%- assign entries = entries | sort: "date" | reverse -%}
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/releases.html' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{% if entries.first %}{{ entries.first.date | date_to_xmlschema }}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</updated>
  <id>{{ '/feed.xml' | absolute_url }}</id>
  <title type="html">{{ site.title | smartify }} — Releases</title>
  <subtitle>Release notes for every version of {{ site.title }}.</subtitle>
  {%- for post in entries limit: 30 -%}
  {%- assign seg = post.url | split: "/" -%}
  {%- assign plat = seg[2] -%}
  {%- assign ver = seg[3] -%}
  {%- case plat -%}
    {%- when "mac" -%}{%- assign platname = "macOS" -%}
    {%- when "windows" -%}{%- assign platname = "Windows" -%}
    {%- when "ios_ipados" -%}{%- assign platname = "iOS / iPadOS" -%}
    {%- when "android" -%}{%- assign platname = "Android" -%}
    {%- else -%}{%- assign platname = plat -%}
  {%- endcase -%}
  {%- assign title = "Glit " | append: ver | append: " — " | append: platname -%}
  <entry>
    <title type="html">{{ title | smartify | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[{{ post.content }}]]></content>
    <summary type="html"><![CDATA[{{ post.content | strip_html | normalize_whitespace | truncate: 300 }}]]></summary>
    <category term="{{ platname | xml_escape }}" />
  </entry>
  {%- endfor -%}
</feed>
